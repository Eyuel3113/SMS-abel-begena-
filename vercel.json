{
    "version": 2,
    "builds": [
        {
            "src": "src/index.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "node_modules/.prisma/client/**",
                    "node_modules/@prisma/client/**",
                    "node_modules/swagger-ui-dist/**",
                    "src/**/*.ts",
                    "dist/**/*.js"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "src/index.ts"
        }
    ]
}